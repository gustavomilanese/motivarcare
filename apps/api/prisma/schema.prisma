generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  PROFESSIONAL
  ADMIN
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum CreditMovementType {
  PACKAGE_PURCHASE
  SESSION_CONSUMED
  SESSION_REFUND
  PENALTY
  ADJUSTMENT
}

enum ConsentType {
  AI_TEXT_AUDIT
  AI_AUDIO_AUDIT
}

/// Mercado comercial para precios, catálogo y preferencia del paciente.
enum Market {
  AR
  US
}

/// Pasarela prevista para el cobro del paquete (Stripe en USA; Mercado Pago en Argentina cuando esté cableado).
enum PackagePaymentProvider {
  STRIPE
  MERCADOPAGO
}

/// Alta de profesional: hasta que un admin apruebe, no aparece en el directorio.
enum ProfessionalRegistrationApproval {
  PENDING
  APPROVED
}

model User {
  id            String               @id @default(cuid())
  email         String               @unique
  emailVerified Boolean              @default(false) @map("email_verified")
  isActive      Boolean              @default(true)
  isTestUser    Boolean              @default(false)
  deactivatedAt DateTime?
  passwordHash  String
  fullName      String
  firstName     String               @default("") @map("first_name")
  lastName      String               @default("") @map("last_name")
  /// Foto de perfil (URL https o data URI).
  avatarUrl     String?              @map("avatar_url") @db.LongText
  role          Role
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  patient       PatientProfile?
  professional  ProfessionalProfile?
  admin         AdminProfile?
  sentMessages  ChatMessage[]        @relation("SentMessages")
  verificationTokens VerificationToken[]
  googleCalendarConnection GoogleCalendarConnection?
}

model VerificationToken {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  token               String   @unique
  type                String
  expiresAt           DateTime @map("expires_at")
  createdAt           DateTime @default(now()) @map("created_at")
  /// Return path on the patient/professional app after Google Calendar OAuth (avoids relying on cross-site cookies).
  calendarReturnPath  String?  @map("calendar_return_path") @db.VarChar(512)
  /// Origin where OAuth started (e.g. http://localhost:5176) so redirect matches localStorage.
  calendarClientOrigin String? @map("calendar_client_origin") @db.VarChar(128)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
  @@map("verification_tokens")
}

model GoogleCalendarConnection {
  id                 String   @id @default(cuid())
  userId             String   @unique
  provider           String   @default("google")
  calendarId         String   @default("primary")
  providerEmail      String?
  refreshToken       String   @db.Text
  accessToken        String?  @db.Text
  scope              String?  @db.Text
  tokenExpiresAt     DateTime?
  connectedAt        DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([provider, calendarId])
}

model PatientProfile {
  id             String                   @id @default(cuid())
  userId         String                   @unique
  /// Catálogo de paquetes y reglas de cobro asociadas (AR por defecto en lanzamiento).
  market         Market                   @default(AR)
  timezone       String                   @default("America/New_York")
  lastSeenTimezone String?
  status         String                   @default("active")
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  user           User                     @relation(fields: [userId], references: [id])
  intake         PatientIntake?
  purchases      PatientPackagePurchase[]
  creditLedger   CreditLedger[]
  bookings       Booking[]                @relation("PatientBookings")
  consents       Consent[]
  chatThreads    ChatThread[]             @relation("PatientThreads")
  aiAuditJobs    AIAuditJob[]
  financeRecords FinanceSessionRecord[]
}

model ProfessionalProfile {
  id                    String                   @id @default(cuid())
  userId                String                   @unique
  timezone              String                   @default("America/New_York")
  lastSeenTimezone      String?
  visible               Boolean                  @default(false)
  professionalTitle     String?
  specialization        String?
  experienceBand        String?
  practiceBand          String?
  gender                String?
  birthCountry          String?
  /// Etiqueta corta legada; preferir `focusAreas`.
  focusPrimary          String?                  @db.VarChar(500)
  /// Lista de áreas de atención (JSON string[]).
  focusAreas            Json?
  languages             Json?
  bio                   String?                  @db.Text
  shortDescription      String?                  @db.Text
  therapeuticApproach   String?                  @db.Text
  yearsExperience       Int?
  /// Año de egreso del título (onboarding); si existe, el matching puede derivar años de práctica.
  graduationYear        Int?                     @map("graduation_year")
  registrationApproval  ProfessionalRegistrationApproval @default(APPROVED) @map("registration_approval")
  sessionPriceUsd       Int?
  discount4             Int?
  discount8             Int?
  discount12            Int?
  photoUrl              String?                  @db.LongText
  videoUrl              String?                  @db.LongText
  videoCoverUrl         String?                  @db.LongText
  stripeDocUrl          String?                  @db.LongText
  stripeVerified        Boolean                  @default(false)
  stripeVerificationStarted Boolean             @default(false)
  cancellationHours     Int                      @default(24)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  user                  User                     @relation(fields: [userId], references: [id])
  availabilitySlots     AvailabilitySlot[]
  bookings              Booking[]                @relation("ProfessionalBookings")
  chatThreads           ChatThread[]             @relation("ProfessionalThreads")
  sessionPackages       SessionPackage[]
  aiAuditJobs           AIAuditJob[]
  diplomas              ProfessionalDiploma[]
  financeRecords        FinanceSessionRecord[]
  payoutLines           FinancePayoutLine[]
}

model ProfessionalDiploma {
  id               String               @id @default(cuid())
  professionalId   String
  institution      String
  degree           String
  startYear        Int
  graduationYear   Int
  documentUrl      String?              @db.LongText
  orderIndex       Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  professional     ProfessionalProfile  @relation(fields: [professionalId], references: [id])

  @@index([professionalId, orderIndex])
}

model AdminProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model PatientIntake {
  id            String         @id @default(cuid())
  patientId     String         @unique
  riskLevel     String         @default("low")
  answers       Json
  createdAt     DateTime       @default(now())
  patient       PatientProfile @relation(fields: [patientId], references: [id])
}

model SessionPackage {
  id                String                   @id @default(cuid())
  professionalId    String?
  /// ID en Stripe (price_…) u otro identificador estable por mercado (único junto con `market`).
  stripePriceId     String
  market            Market                   @default(AR)
  paymentProvider   PackagePaymentProvider   @default(STRIPE)
  name              String
  credits           Int
  priceCents        Int
  discountPercent   Int                      @default(0)
  currency          String                   @default("usd")
  active            Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  purchases         PatientPackagePurchase[]
  professional      ProfessionalProfile?     @relation(fields: [professionalId], references: [id])
  financeRecords    FinanceSessionRecord[]

  @@unique([market, stripePriceId])
}

model PatientPackagePurchase {
  id                       String         @id @default(cuid())
  patientId                String
  packageId                String
  stripeCheckoutSessionId  String         @unique
  totalCredits             Int
  remainingCredits         Int
  packageNameSnapshot      String?
  packageCreditsSnapshot   Int?
  packageListPriceCentsSnapshot Int?
  packagePriceCentsSnapshot Int?
  packageDiscountPercentSnapshot Int?
  packageCurrencySnapshot  String?
  platformCommissionPercentSnapshot Int?
  trialPlatformPercentSnapshot Int?
  professionalIdSnapshot   String?
  purchasedAt              DateTime       @default(now())
  patient                  PatientProfile @relation(fields: [patientId], references: [id])
  sessionPackage           SessionPackage @relation(fields: [packageId], references: [id])
  financeRecords           FinanceSessionRecord[]
}

model CreditLedger {
  id            String             @id @default(cuid())
  patientId     String
  bookingId     String?
  type          CreditMovementType
  amount        Int
  note          String?
  createdAt     DateTime           @default(now())
  patient       PatientProfile     @relation(fields: [patientId], references: [id])
  booking       Booking?           @relation(fields: [bookingId], references: [id])
}

model AvailabilitySlot {
  id              String               @id @default(cuid())
  professionalId  String
  startsAt        DateTime
  endsAt          DateTime
  isBlocked       Boolean              @default(false)
  source          String               @default("internal")
  createdAt       DateTime             @default(now())
  professional    ProfessionalProfile  @relation(fields: [professionalId], references: [id])

  @@index([professionalId, startsAt])
}

model Booking {
  id                 String               @id @default(cuid())
  patientId          String
  professionalId     String
  consumedPurchaseId String?
  patientTimezoneAtBooking String         @default("UTC")
  professionalTimezoneAtBooking String    @default("UTC")
  startsAt           DateTime
  endsAt             DateTime
  status             BookingStatus        @default(REQUESTED)
  cancellationReason String?
  cancelledAt        DateTime?
  completedAt        DateTime?
  consumedCredits    Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  patient            PatientProfile       @relation("PatientBookings", fields: [patientId], references: [id])
  professional       ProfessionalProfile  @relation("ProfessionalBookings", fields: [professionalId], references: [id])
  chatThread         ChatThread?
  videoSession       VideoSession?
  creditMovements    CreditLedger[]
  financeRecord      FinanceSessionRecord?

  @@index([patientId, startsAt])
  @@index([professionalId, startsAt])
  @@index([consumedPurchaseId])
  @@index([professionalId, startsAt, endsAt])
}

model FinanceSessionRecord {
  id                         String               @id @default(cuid())
  bookingId                  String               @unique
  patientId                  String
  professionalId             String
  packageId                  String?
  purchaseId                 String?
  payoutLineId               String?
  isTrial                    Boolean              @default(false)
  currency                   String               @default("usd")
  sessionPriceCents          Int
  platformCommissionPercent  Int
  platformFeeCents           Int
  professionalNetCents       Int
  bookingStatus              BookingStatus
  bookingCompletedAt         DateTime?
  bookingStartsAt            DateTime
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  booking                    Booking              @relation(fields: [bookingId], references: [id])
  patient                    PatientProfile       @relation(fields: [patientId], references: [id])
  professional               ProfessionalProfile  @relation(fields: [professionalId], references: [id])
  package                    SessionPackage?      @relation(fields: [packageId], references: [id])
  purchase                   PatientPackagePurchase? @relation(fields: [purchaseId], references: [id])
  payoutLine                 FinancePayoutLine?   @relation(fields: [payoutLineId], references: [id])

  @@index([bookingCompletedAt])
  @@index([professionalId, bookingCompletedAt])
  @@index([patientId, bookingCompletedAt])
  @@index([packageId, bookingCompletedAt])
  @@index([payoutLineId])
}

model FinancePayoutRun {
  id               String              @id @default(cuid())
  idempotencyKey   String?             @unique
  periodStart      DateTime
  periodEnd        DateTime
  status           String              @default("DRAFT")
  totalGrossCents  Int                 @default(0)
  totalFeeCents    Int                 @default(0)
  totalNetCents    Int                 @default(0)
  notes            String?             @db.Text
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  closedAt         DateTime?
  payoutLines      FinancePayoutLine[]

  @@index([periodStart, periodEnd])
}

model FinancePayoutLine {
  id                    String               @id @default(cuid())
  payoutRunId           String
  professionalId        String
  sessionsCount         Int                  @default(0)
  grossCents            Int                  @default(0)
  platformFeeCents      Int                  @default(0)
  professionalNetCents  Int                  @default(0)
  status                String               @default("PENDING")
  paidAt                DateTime?
  payoutReference       String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  payoutRun             FinancePayoutRun     @relation(fields: [payoutRunId], references: [id])
  professional          ProfessionalProfile  @relation(fields: [professionalId], references: [id])
  sessionRecords        FinanceSessionRecord[]

  @@index([payoutRunId, professionalId])
  @@index([status, paidAt])
}

model ChatThread {
  id               String               @id @default(cuid())
  patientId        String
  professionalId   String
  bookingId        String?              @unique
  createdAt        DateTime             @default(now())
  patient          PatientProfile       @relation("PatientThreads", fields: [patientId], references: [id])
  professional     ProfessionalProfile  @relation("ProfessionalThreads", fields: [professionalId], references: [id])
  booking          Booking?             @relation(fields: [bookingId], references: [id])
  messages         ChatMessage[]
}

model ChatMessage {
  id             String    @id @default(cuid())
  threadId       String
  senderUserId   String
  body           String    @db.Text
  readAt         DateTime?
  createdAt      DateTime  @default(now())
  thread         ChatThread @relation(fields: [threadId], references: [id])
  sender         User       @relation("SentMessages", fields: [senderUserId], references: [id])

  @@index([threadId, createdAt])
}

model VideoSession {
  id                  String    @id @default(cuid())
  bookingId           String    @unique
  provider            String    @default("daily")
  externalRoomId      String
  joinUrlPatient      String    @db.Text
  joinUrlProfessional String    @db.Text
  createdAt           DateTime  @default(now())
  booking             Booking   @relation(fields: [bookingId], references: [id])
}

model Consent {
  id            String       @id @default(cuid())
  patientId     String
  type          ConsentType
  granted       Boolean
  grantedAt     DateTime     @default(now())
  patient       PatientProfile @relation(fields: [patientId], references: [id])

  @@unique([patientId, type])
}

model AIAuditJob {
  id               String               @id @default(cuid())
  patientId        String?
  professionalId   String?
  bookingId        String?
  mode             String               @default("text")
  source           String
  status           String               @default("queued")
  payload          Json?
  result           Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  patient          PatientProfile?      @relation(fields: [patientId], references: [id])
  professional     ProfessionalProfile? @relation(fields: [professionalId], references: [id])
}

model SystemConfig {
  id         String   @id @default(cuid())
  key        String   @unique
  value      Json
  updatedAt  DateTime @updatedAt
}

model FinanceDailyAggregate {
  id                   String   @id @default(cuid())
  day                  DateTime
  currency             String
  sessionsCount        Int      @default(0)
  grossCents           Int      @default(0)
  platformFeeCents     Int      @default(0)
  professionalNetCents Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([day, currency])
  @@index([day])
}

model OutboxEvent {
  id            String   @id @default(cuid())
  dedupeKey     String?  @unique
  eventType     String
  aggregateType String
  aggregateId   String?
  payload       Json
  status        String   @default("PENDING")
  attempts      Int      @default(0)
  availableAt   DateTime @default(now())
  processedAt   DateTime?
  errorMessage  String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, availableAt])
  @@index([createdAt])
}
