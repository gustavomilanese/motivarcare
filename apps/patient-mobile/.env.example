# Copiá a .env en esta carpeta (apps/patient-mobile). Expo carga EXPO_PUBLIC_* al bundlear.

# URL del API (sin barra final).
# — Simulador iOS con API en la Mac: http://localhost:4000
# — Emulador Android: http://10.0.2.2:4000
# — Teléfono físico (misma Wi‑Fi): http://TU_IP_LAN:4000  (ej. http://192.168.1.42:4000)
# Si no definís nada, el cliente usa http://localhost:4000 (falla en dispositivo real).
# EXPO_PUBLIC_API_URL=http://192.168.1.42:4000

# Si el teléfono no alcanza el bundler Metro, probá la IP de tu Mac (misma red):
# REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.42
