# API
PORT=4000
# En development el API ya escucha en 0.0.0.0 por defecto (móvil en la misma Wi‑Fi). Para forzar otro bind:
# API_LISTEN_HOST=127.0.0.1
NODE_ENV=development
TRUST_PROXY=true
DATABASE_URL=mysql://root:root@localhost:3307/therapy_platform
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:5172,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=300
API_RATE_LIMIT_BACKEND=auto
API_AUTH_LOGIN_WINDOW_MS=600000
API_AUTH_LOGIN_MAX_ATTEMPTS=20
API_MAX_INFLIGHT_REQUESTS=500
API_REQUEST_TIMEOUT_MS=30000
API_MAX_REQUESTS_PER_SOCKET=1000
API_ACCESS_LOG_ENABLED=true
API_METRICS_ENABLED=true
API_BOOKING_LOCK_TTL_MS=8000
API_SHUTDOWN_GRACE_MS=15000
OUTBOX_POLL_MS=2000
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_ATTEMPTS=12
OUTBOX_RETRY_BASE_MS=10000

# Auth
JWT_SECRET=replace_me
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
PATIENT_APP_URL=http://localhost:5173
PROFESSIONAL_APP_URL=http://localhost:5174
ADMIN_APP_URL=http://localhost:5175
EMAIL_FROM=MotivarCare <no-reply@motivacare.app>
RESEND_API_KEY=

# Stripe (USA)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PACKAGE_4=price_xxx
STRIPE_PRICE_PACKAGE_8=price_xxx
STRIPE_PRICE_PACKAGE_12=price_xxx
# Optional multi-currency price map (recommended)
# Example:
# STRIPE_PRICE_MAP_JSON={"USD":{"4":"price_usd_4","8":"price_usd_8","12":"price_usd_12"},"EUR":{"4":"price_eur_4","8":"price_eur_8","12":"price_eur_12"}}
STRIPE_PRICE_MAP_JSON=

# Daily (video)
DAILY_API_KEY=xxx
DAILY_DOMAIN=https://your-team.daily.co

# AI
OPENAI_API_KEY=xxx
AI_AUDIT_ENABLED=false
