# Frontends Vite (paciente / admin / pro): leen este repo vía envDir. En http://localhost:* el cliente usa
# rutas relativas /api... y Vite las proxifica a http://127.0.0.1:${PORT} (misma variable PORT de abajo; default 4000).
# `npm run dev` y `npm run dev:all` levantan primero Docker (MySQL + Redis) y esperan al puerto MySQL; después arrancan los Vite + API.
# Si no usás Docker local: `npm run dev:all:apps` o `npm run dev:apps` (solo procesos, sin db:pre).
# ECONNREFUSED en el proxy: revisá la salida [API] (crash al arrancar, MySQL, puerto 4000 ocupado → `npm run dev:kill`). Los Vite esperan a que :4000 acepte TCP.
# PORT debe coincidir con el API; el proxy de Vite lo lee de este archivo.
# Para hablar con el API remoto desde el front local: VITE_API_URL + VITE_FORCE_REMOTE_API=true
# VITE_API_URL=https://tu-api.railway.app
# VITE_FORCE_REMOTE_API=true

# API
PORT=4000
# En development el API ya escucha en 0.0.0.0 por defecto (móvil en la misma Wi‑Fi). Para forzar otro bind:
# API_LISTEN_HOST=127.0.0.1
NODE_ENV=development
TRUST_PROXY=true
# Si Prisma no conecta en Mac, probá host 127.0.0.1 en lugar de localhost.
DATABASE_URL=mysql://root:root@127.0.0.1:3307/therapy_platform
# Railway (solo servicio outbox / worker): evita repetir `prisma db push` en el release (ver `railway.toml` / DEPLOY.md).
# SKIP_RELEASE_DB_PUSH=1
REDIS_URL=redis://localhost:6379
# En local: `auto` o `memory` si no levantás Redis (Docker). Si copiás prod con `redis` y no hay Redis,
# en development el API usa rate limit en memoria igualmente; en production sigue siendo obligatorio Redis.
API_RATE_LIMIT_BACKEND=auto
# Incluir en prod las URLs HTTPS de Vercel (paciente, admin, pro, etc.) sin barra final; si falta, fetch() al API falla en el navegador.
CORS_ORIGINS=http://localhost:5172,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=300
# Con `Authorization: Bearer` el límite por IP es este (portales con muchas peticiones en paralelo).
API_RATE_LIMIT_MAX_REQUESTS_AUTHENTICATED=2000
API_AUTH_LOGIN_WINDOW_MS=600000
API_AUTH_LOGIN_MAX_ATTEMPTS=20
API_MAX_INFLIGHT_REQUESTS=500
API_REQUEST_TIMEOUT_MS=30000
API_MAX_REQUESTS_PER_SOCKET=1000
API_ACCESS_LOG_ENABLED=true
API_METRICS_ENABLED=true
API_BOOKING_LOCK_TTL_MS=8000
API_SHUTDOWN_GRACE_MS=15000
OUTBOX_POLL_MS=2000
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_ATTEMPTS=12
OUTBOX_RETRY_BASE_MS=10000

# Auth
JWT_SECRET=replace_me
# false = registro sin paso de mail en local (default si omitís la variable y NODE_ENV≠production).
# true = mismo flujo que prod; sin RESEND_API_KEY el enlace suele loguearse en la consola del API.
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
# En producción: URLs públicas HTTPS de cada frontend (los enlaces de verificación de email usan estas variables).
PATIENT_APP_URL=http://localhost:5173
PROFESSIONAL_APP_URL=http://localhost:5174
# En prod: la URL que ve el navegador (origen); el API la usa también para CORS junto con CORS_ORIGINS.
ADMIN_APP_URL=http://localhost:5175
# Transaccional (Resend): con RESEND_API_KEY el API envía verificación y otros mails vía https://api.resend.com
# Sin clave, el enlace de verificación se loguea en la consola del API (ver evento email_verification_link_generated).
# Para probar sin dominio propio: EMAIL_FROM=MotivarCare <onboarding@resend.dev> (límites según cuenta Resend).
EMAIL_FROM=MotivarCare <onboarding@resend.dev>
RESEND_API_KEY=

# Stripe (USA)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PACKAGE_4=price_xxx
STRIPE_PRICE_PACKAGE_8=price_xxx
STRIPE_PRICE_PACKAGE_12=price_xxx
# Optional multi-currency price map (recommended)
# Example:
# STRIPE_PRICE_MAP_JSON={"USD":{"4":"price_usd_4","8":"price_usd_8","12":"price_usd_12"},"EUR":{"4":"price_eur_4","8":"price_eur_8","12":"price_eur_12"}}
STRIPE_PRICE_MAP_JSON=

# Daily (video)
DAILY_API_KEY=xxx
DAILY_DOMAIN=https://your-team.daily.co

# --- Google: Calendar (OAuth en app) + Meet en cada reserva ---
# Sin GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET el POST /api/auth/google/calendar/connect devuelve 503
# (GOOGLE_CALENDAR_OAUTH_NOT_CONFIGURED) y el paciente ve el mensaje rojo al pulsar «Conectar ahora».
# En Google Cloud: habilitá «Google Calendar API», pantalla de consentimiento OAuth, credencial tipo «Aplicación web».
# Orígenes JS autorizados (ej.): http://localhost:5173
# Misma app OAuth en Google Cloud Console (tipo «Aplicación web»).
# En «URI de redireccionamiento autorizadas» agregá EXACTAMENTE (sin barra final en el host):
#   {API_PUBLIC_URL}/api/auth/google/calendar/callback
# Ejemplo local: http://localhost:4000/api/auth/google/calendar/callback
# Si el API lo abrís como http://127.0.0.1:4000, API_PUBLIC_URL y esa URI deben usar 127.0.0.1 (no mezclar con localhost).
# GOOGLE_CLIENT_ID y GOOGLE_CLIENT_SECRET deben ser del mismo proyecto que esa URI.
API_PUBLIC_URL=http://localhost:4000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
#
# Meet en LOCAL (recomendado): además del client id/secret, rellená las dos de abajo con un refresh token
# de la MISMA app OAuth y el calendarId (casi siempre "primary"). Así cada reserva crea Meet sin que cada
# usuario demo haya pulsado “Conectar calendario”. En NODE_ENV=development el API intenta ESTE calendario
# antes que el del profesional/paciente. Generá el refresh con OAuth 2.0 Playground o un script offline.
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
#
# Producción: orden de intentos = profesional enlazado → paciente enlazado → estas variables (plataforma).
# Si falta cualquier pieza, el enlace de video queda en Daily de respaldo (ver logs al arrancar el API y al reservar).

# AI
OPENAI_API_KEY=xxx
AI_AUDIT_ENABLED=false
