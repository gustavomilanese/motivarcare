{
  "name": "therapy-platform",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n API,PATIENT,PRO,ADMIN -c cyan,magenta,green,yellow \"npm run dev:api\" \"npm run dev:patient\" \"npm run dev:professional\" \"npm run dev:admin\"",
    "dev:all": "concurrently -n API,LANDING,PATIENT,PRO,ADMIN -c cyan,blue,magenta,green,yellow \"npm run dev:api\" \"npm run dev:landing\" \"npm run dev:patient\" \"npm run dev:professional\" \"npm run dev:admin\"",
    "dev:full": "npm run db:up && npm run db:wait && npm run dev:all",
    "dev:kill": "bash scripts/kill-dev-ports.sh",
    "dev:api": "npm run dev -w @therapy/api",
    "dev:patient": "npm run dev -w @therapy/patient",
    "dev:patient-mobile": "npm run start -w @therapy/patient-mobile",
    "dev:patient-mobile:clear": "npm run start:clear -w @therapy/patient-mobile",
    "dev:professional": "npm run dev -w @therapy/professional",
    "dev:admin": "npm run dev -w @therapy/admin",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:up": "docker compose -f infra/docker/docker-compose.yml up -d mysql redis",
    "db:wait": "node scripts/wait-for-mysql.mjs",
    "db:down": "docker compose -f infra/docker/docker-compose.yml down",
    "dev:stop": "npm run db:down",
    "db:push": "npm run prisma:push -w @therapy/api",
    "db:sync": "npm run db:up && npm run db:wait && npm run db:push",
    "db:seed": "npm run prisma:seed -w @therapy/api",
    "db:wipe-non-admin": "npm run db:wipe-non-admin -w @therapy/api",
    "dev:landing": "npm run dev -w @therapy/landing",
    "test": "npm run test --workspaces --if-present",
    "load:smoke": "node scripts/load/smoke.mjs",
    "prisma:generate:api": "prisma generate --schema=./apps/api/prisma/schema.prisma",
    "build:api": "npm run prisma:generate:api && npm run build -w @therapy/api",
    "db:push:remote": "npm run prisma:push -w @therapy/api",
    "db:push:remote:accept-data-loss": "npm run prisma:push -w @therapy/api -- --accept-data-loss"
  },
  "devDependencies": {
    "autocannon": "^8.0.0",
    "concurrently": "^9.2.1",
    "prisma": "^6.19.3"
  }
}
