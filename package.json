{
  "name": "therapy-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n API,PATIENT,PRO,ADMIN -c cyan,magenta,green,yellow \"npm run dev:api\" \"npm run dev:patient\" \"npm run dev:professional\" \"npm run dev:admin\"",
    "dev:api": "npm run dev -w @therapy/api",
    "dev:patient": "npm run dev -w @therapy/patient-web",
    "dev:professional": "npm run dev -w @therapy/professional-web",
    "dev:admin": "npm run dev -w @therapy/admin-web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
